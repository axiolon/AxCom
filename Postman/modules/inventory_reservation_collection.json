{
  "info": {
    "_postman_id": "c1a898b9-5f2c-4a37-b957-61c02abdfcf4",
    "name": "Ecom Engine - Inventory (Reservation)",
    "description": "Postman collection for locking and releasing inventory stock items during customer checkouts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Reserve Stock",
      "request": {
        "body": {
          "mode": "raw",
          "raw": "{\n    \"location_id\": \"default\",\n    \"quantity\": 2\n}"
        },
        "description": "Places a stock lock reservation on a product variant. Requires authentication.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "POST",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "inventory",
            "var_123",
            "reserve"
          ],
          "raw": "{{base_url}}/api/inventory/var_123/reserve"
        }
      },
      "response": []
    },
    {
      "name": "Release Reservation",
      "request": {
        "description": "Releases a locked reservation back into active inventory status. Requires authentication.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "DELETE",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "inventory",
            "var_123",
            "reserve",
            "res_987"
          ],
          "raw": "{{base_url}}/api/inventory/var_123/reserve/res_987"
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}