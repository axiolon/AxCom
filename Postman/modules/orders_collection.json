  "item": [
    {
      "description": "Endpoints for authenticated customer order flows.",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n    \"items\": [\n        {\n            \"variant_id\": \"var_123\",\n            \"quantity\": 2,\n            \"price\": 29.99\n        }\n    ]\n}"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "description": "Customer bearer token",
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "method": "POST",
            "url": {
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "orders"
              ],
              "raw": "{{base_url}}/api/orders"
