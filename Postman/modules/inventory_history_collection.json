{
  "info": {
    "_postman_id": "c1a898b9-5f2c-4a37-b957-61c02abdfcf8",
    "name": "Ecom Engine - Inventory (History)",
    "description": "Postman collection for fetching historical stock change logs of a product variant.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Variant Stock History",
      "request": {
        "description": "Retrieves the audit log of all stock updates, additions, and adjustments made to the specified variant ID across locations. Requires authentication.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "GET",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "inventory",
            "var_123",
            "history"
          ],
          "raw": "{{base_url}}/api/inventory/var_123/history"
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}