{
  "info": {
    "_postman_id": "b182cb68-7cfa-4929-a1b7-90c763914a22",
    "name": "Ecom Engine - Catalog (Variants)",
    "description": "Postman collection for testing the product variants endpoints of the ecom-engine API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Variants",
      "request": {
        "description": "Retrieves all variants associated with a specific product ID. Publicly accessible.",
        "header": [],
        "method": "GET",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "{{product_id}}",
            "variants"
          ],
          "raw": "{{base_url}}/api/products/{{product_id}}/variants"
        }
      },
      "response": []
    },
    {
      "name": "Add Variant",
      "request": {
        "body": {
          "mode": "raw",
          "raw": "{\n    \"sku\": \"MS-WIRE-BLK-01\",\n    \"name\": \"Black Edition\",\n    \"price\": 49.99,\n    \"attributes\": {\n        \"color\": \"Black\",\n        \"connectivity\": \"Wireless\"\n    }\n}"
        },
        "description": "Adds a new variant to an existing product. Requires authenticated admin/authorized user token.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "POST",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "{{product_id}}",
            "variants"
          ],
          "raw": "{{base_url}}/api/products/{{product_id}}/variants"
        }
      },
      "response": []
    },
    {
      "name": "Update Variant",
      "request": {
        "body": {
          "mode": "raw",
          "raw": "{\n    \"sku\": \"MS-WIRE-BLK-01-UPDATED\",\n    \"name\": \"Black Edition Pro\",\n    \"price\": 54.99,\n    \"attributes\": {\n        \"color\": \"Matte Black\",\n        \"connectivity\": \"Wireless/USB-C\"\n    }\n}"
        },
        "description": "Updates an existing variant for a product. Requires authenticated admin/authorized user token.",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "PUT",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "{{product_id}}",
            "variants",
            "{{variant_id}}"
          ],
          "raw": "{{base_url}}/api/products/{{product_id}}/variants/{{variant_id}}"
        }
      },
      "response": []
    },
    {
      "name": "Delete Variant",
      "request": {
        "description": "Deletes a variant from a product. A product must retain at least one variant. Requires authenticated admin/authorized user token.",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "method": "DELETE",
        "url": {
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "{{product_id}}",
            "variants",
            "{{variant_id}}"
          ],
          "raw": "{{base_url}}/api/products/{{product_id}}/variants/{{variant_id}}"
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "prod_123",
      "type": "string"
    },
    {
      "key": "variant_id",
      "value": "var_456",
      "type": "string"
    }
  ]
}