        {
          "name": "Create Product",
          "request": {
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Smartphone X\",\n    \"description\": \"Flagship phone\",\n    \"category_id\": \"cat_123\",\n    \"variants\": [\n        {\n            \"sku\": \"SM-X-01\",\n            \"name\": \"Black 128GB\",\n            \"price\": 999.99\n        }\n    ]\n}"
            },
            "description": "Creates a new catalog product with its associated variants. Requires authenticated token.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "method": "POST",
            "url": {
              "host": [
                "{{base_url}}"
