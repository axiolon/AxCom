#
# Monitoring stack environment variables.
# Copy to .env and adjust before running docker compose up.

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme          # CHANGE in any shared/staging environment

# ── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Loki ────────────────────────────────────────────────────────────────────
LOKI_PORT=3100

# ── Tempo ────────────────────────────────────────────────────────────────────
TEMPO_PORT=3200

# ── OTel Collector ──────────────────────────────────────────────────────────
OTEL_GRPC_PORT=4317                # OTLP gRPC — app SDK: OTEL_EXPORTER_OTLP_ENDPOINT=http://<host>:4317
OTEL_HTTP_PORT=4318                # OTLP HTTP — app SDK: OTEL_EXPORTER_OTLP_ENDPOINT=http://<host>:4318

# ── Grafana Cloud (used only with docker-compose.cloud.yml) ──────────────────
# GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_CLOUD_INSTANCE_ID=123456
# GRAFANA_CLOUD_API_KEY=glc_eyJ...
