# Ecom Engine Environment Configuration Example
# Copy this file to .env.dev, .env.prod, etc. and fill in the values.

# Server settings
PORT=8080
JWT_SECRET=your-secure-jwt-secret-key

# Database settings
DB_TYPE=mongodb # postgres or mongodb
DB_CONNECTION_STRING=mongodb://localhost:27017/ecom_db?replicaSet=rs0&directConnection=true

# Payment provider settings
PAYMENT_PROVIDER=stripe # stripe, payhere, paypal
PAYMENT_API_KEY=your-payment-provider-api-key

# OpenTelemetry configuration
OTEL_ENABLED=false
OTEL_TRACE_SAMPLE=1.0
OTEL_EXPORTER=none # none or otlp
OTEL_SERVICE_NAME=ecom-engine
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318



# Event Bus / Messaging Configuration
EVENT_PROVIDER=local # local, kafka, rabbitmq
EVENT_MAX_RETRIES=3
EVENT_INITIAL_BACKOFF_MS=50
EVENT_MAX_BACKOFF_MS=2000
EVENT_LOCAL_DLQ_SIZE=100

# Kafka settings (used if EVENT_PROVIDER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=ecom-engine-group
KAFKA_CLIENT_ID=ecom-engine-client
KAFKA_DLQ_TOPIC=events.dlq
KAFKA_AUTO_OFFSET_RESET_LATEST=false

# RabbitMQ settings (used if EVENT_PROVIDER=rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=ecom_events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_QUEUE=ecom_queue
RABBITMQ_DLQ_EXCHANGE=ecom_events_dlq
RABBITMQ_DLQ_QUEUE=ecom_queue_dlq

# File Storage Configuration
STORAGE_PROVIDER=local # local, s3, r2
STORAGE_BUCKET=products
STORAGE_REGION=us-east-1 # AWS region (s3 only)
STORAGE_ACCOUNT_ID= # Cloudflare R2 Account ID (r2 only)
STORAGE_ACCESS_KEY_ID= # AWS/R2 Access Key ID (optional static override, leave empty for IAM on AWS)
STORAGE_SECRET_ACCESS_KEY= # AWS/R2 Secret Access Key (optional static override)
